# Environment Variables

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# JWT (required for user auth)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin panel secret (required for /admin)
ADMIN_SECRET=your-admin-panel-password-change-this

# Lipana (MPesa STK Push)
LIPANA_SECRET_KEY=lip_sk_test_or_live_...
LIPANA_PUBLISHABLE_KEY=lip_pk_test_or_live_...
LIPANA_WEBHOOK_SECRET=your-webhook-secret
LIPANA_BASE_URL=https://api.lipana.dev/v1

# NODE_ENV (Vercel sets this automatically)
NODE_ENV=production
